```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Build directories
dist/
build/
target/
*.log
*.tmp
*.swp
*.swo

# Editors
.vscode/
.idea/

# System files
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Compression
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# Python specific
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/

# JavaScript/Node specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Java specific
.gradle/
*.jar
*.war
*.ear

# Go specific
*.exe
*.test
vendor/

# C/C++ specific
*.a
*.lib
*.dll
*.so
*.dylib
*.dSYM/

# Ruby specific
*.gem
*.rbc
.bundle/
.rbenv-gemsets/
.rbenv-version/

# Rust specific
target/
Cargo.lock

# Julia specific
julia-*/

# Zig specific
zig*/
```